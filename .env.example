# ============================================================
# FILE MẪU BIẾN MÔI TRƯỜNG
# Copy file này thành ".env" rồi điền giá trị thật.
# KHÔNG commit file .env (chứa mật khẩu) lên git.
# ============================================================

# --- PostgreSQL (database chính + pgvector) ---
# Định dạng: postgresql://user:password@host:port/tendb
DATABASE_URL="postgresql://shop:shop_password@localhost:5432/shop_db?schema=public"

# --- Redis (cache, lưu session, hàng đợi) ---
REDIS_URL="redis://localhost:6379"

# --- Khóa bí mật ký JWT (token đăng nhập) ---
# Trong thực tế phải là chuỗi ngẫu nhiên dài, giữ tuyệt mật.
JWT_SECRET="doi-thanh-chuoi-bi-mat-that-dai-va-ngau-nhien-trong-thuc-te"

# --- URL gốc của ứng dụng (dùng cho client gọi API) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- OpenAI (tùy chọn — embedding chất lượng cao hơn) ---
# OPENAI_API_KEY="sk-..."
